# Railway Environment Variables
# Copy these to your Railway backend service settings

# Security (REQUIRED - Change these!)
MASTER_API_KEY=your-secure-random-key-here-change-this
SECRET_KEY=your-secret-key-here-change-this

# Database (Auto-set by Railway PostgreSQL)
DATABASE_URL=postgresql://...

# Redis (Auto-set by Railway Redis)
REDIS_URL=redis://...

# CORS - Add your Vercel URLs after deployment
CORS_ORIGINS=https://your-demo.vercel.app,https://your-customer.vercel.app,http://localhost:3000,http://localhost:3001

# API Configuration
API_V1_PREFIX=/v1
PROJECT_NAME=AI Whale Service
VERSION=1.0.0

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# Rate Limiting (Optional)
RATE_LIMIT_PER_MINUTE=60

# Monitoring (Optional)
# SENTRY_DSN=https://...@sentry.io/...

# Generate secure keys with:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
