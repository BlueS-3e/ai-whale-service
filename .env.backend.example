# .env.example - Copy to .env and fill in your values

# Application Settings
PROJECT_NAME="AI Whale Service"
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# API Keys
MASTER_API_KEY=supersecretkey

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aiwhale
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8000"]

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Blockchain RPC Endpoints (Free tier)
ETHEREUM_RPC_URL=https://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org

# WebSocket Endpoints (Optional - for real-time)
ETHEREUM_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/demo
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Blockchain Explorers (for verification)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# Paid RPC Services (Better performance - optional)
# ALCHEMY_API_KEY=
# INFURA_API_KEY=
# QUICKNODE_URL=

# Social Media APIs (Future)
# TWITTER_BEARER_TOKEN=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# AI/ML Models
MODEL_PATH=./models
RETRAIN_INTERVAL_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/app.log
