# BNB Whale AI - Development Configuration
# Safe for judges to run project - No secrets included

# Database (Local Development)
DATABASE_URL=postgresql://user:pass@localhost:5432/aiwhale

# Redis (Local Development)
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_KEY_HEADER=X-API-Key
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

# Blockchain Configuration - BSC Testnet
# Smart Contract deployed at: https://testnet.bscscan.com/address/0x15152C17aB0078A910C792aBF71F0c54BB41e13E
CONTRACT_ADDRESS=0x15152C17aB0078A910C792aBF71F0c54BB41e13E
CONTRACT_CHAIN=bsc
CONTRACT_GAS_LIMIT=200000

# RPC Endpoints (Public)
BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
ETHEREUM_RPC_URL=https://eth.llamarpc.com
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WEB3_NETWORK=bsc-testnet

# Model Configuration
MODEL_PATH=./models/

# External APIs (Optional - Leave blank for development)
TWITTER_BEARER_TOKEN=
ETHERSCAN_API_KEY=
OPENAI_API_KEY=
