# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/aiwhale

# Redis
REDIS_URL=redis://localhost:6379/0

# API Security
API_KEY_HEADER=X-API-Key
MASTER_API_KEY=supersecretkey

# Model paths
MODEL_PATH=./models/

# External APIs (optional)
TWITTER_BEARER_TOKEN=
ETHERSCAN_API_KEY=
OPENAI_API_KEY=

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=True

# Logging
LOG_LEVEL=INFO
