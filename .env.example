# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/aiwhale

# Redis
REDIS_URL=redis://localhost:6379/0

# API Security
API_KEY_HEADER=X-API-Key
MASTER_API_KEY=supersecretkey

# Model paths
MODEL_PATH=./models/

# External APIs (optional)
TWITTER_BEARER_TOKEN=
ETHERSCAN_API_KEY=
OPENAI_API_KEY=

# Blockchain RPC Endpoints
ETHEREUM_RPC_URL=https://eth.llamarpc.com
POLYGON_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org/
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org

# Smart Contract Configuration (for BNB Hack)
# Deploy WhalePredictor contract, then add address and private key below
CONTRACT_ADDRESS=0xYourDeployedContractAddress
CONTRACT_PRIVATE_KEY=your_private_key_without_0x
CONTRACT_CHAIN=bsc
CONTRACT_GAS_LIMIT=200000

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=True

# Logging
LOG_LEVEL=INFO
